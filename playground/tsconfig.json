{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "strict": true,
    "target": "ES2015",
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["typings/**/*", "src/**/*", "src/**/*.vue", "build/**/*.ts"]
}
