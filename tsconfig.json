{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "strict": true,
    "target": "ES2015",
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "verbatimModuleSyntax": true,
    "lib": ["esnext", "dom"]
  },
  "exclude": ["scripts/**/*", "beifen/**/*", "playground/**/*"]
}
