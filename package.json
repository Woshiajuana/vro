{
  "name": "@vrojs/monorepo",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "description": "基于 vue 的 ui 组件库",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm -C ./playground dev",
    "build": "pnpm -C ./playground build",
    "lint": "eslint . --fix",
    "build:base": "pnpm -C ./packages/base build",
    "build:element-plus": "pnpm -C ./packages/element-plus build",
    "build:vant": "pnpm -C ./packages/vant build",
    "build:resolver": "pnpm -C ./packages/resolver build",
    "build:use": "pnpm -C ./packages/use build",
    "npm-release": "npm run npm-release:use && npm run npm-release:resolver && npm run npm-release:base && npm run npm-release:element-plus && npm run npm-release:vant",
    "npm-release:base": "npm run plop sync-style-deps base && pnpm -C ./packages/base release",
    "npm-release:element-plus": "npm run plop sync-style-deps element-plus && pnpm -C ./packages/element-plus release",
    "npm-release:resolver": "pnpm -C ./packages/resolver release",
    "npm-release:use": "pnpm -C ./packages/use release",
    "npm-release:vant": "npm run plop sync-style-deps vant && pnpm -C ./packages/vant release",
    "sync": "npm run sync:use && npm run sync:resolvers && npm run sync:base && npm run sync:element-plus && npm run sync:vant",
    "sync:base": "pnpm -C ./packages/base sync",
    "sync:element-plus": "pnpm -C ./packages/element-plus sync",
    "sync:resolver": "pnpm -C ./packages/resolver sync",
    "sync:use": "pnpm -C ./packages/use sync",
    "sync:vant": "pnpm -C ./packages/vant sync",
    "plop": "plop --plopfile=./scripts/index.ts",
    "clean": "rimraf --glob **/node_modules",
    "preinstall": "npx only-allow pnpm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Woshiajuana/vrojs.git"
  },
  "keywords": [
    "vue",
    "ui",
    "vrojs"
  ],
  "author": "woshiajuana",
  "license": "ISC",
  "engines": {
    "node": ">= 20",
    "pnpm": ">= 7.0.0"
  },
  "bugs": {
    "url": "https://github.com/Woshiajuana/vrojs/issues"
  },
  "homepage": "https://github.com/Woshiajuana/vrojs#readme",
  "devDependencies": {
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.38.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^10.5.1",
    "jiti": "^2.7.0",
    "fast-glob": "^3.3.3",
    "plop": "^4.0.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  }
}
