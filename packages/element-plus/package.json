{
  "name": "@vrojs/element-plus",
  "version": "0.0.2",
  "description": "vrojs ui",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style": {
      "types": "./dist/style/index.d.ts",
      "import": "./dist/style/index.js",
      "default": "./dist/style/index.js"
    },
    "./style/css": {
      "types": "./dist/style/css.d.ts",
      "import": "./dist/style/css.js",
      "default": "./dist/style/css.js"
    },
    "./style/deps": {
      "types": "./dist/style/deps.d.ts",
      "import": "./dist/style/deps.js",
      "default": "./dist/style/deps.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "default": "./dist/*/index.js"
    },
    "./*/style": {
      "types": "./dist/*/style/index.d.ts",
      "import": "./dist/*/style/index.js",
      "default": "./dist/*/style/index.js"
    },
    "./*/style/css": {
      "types": "./dist/*/style/css.d.ts",
      "import": "./dist/*/style/css.js",
      "default": "./dist/*/style/css.js"
    },
    "./*/style/deps": {
      "types": "./dist/*/style/deps.d.ts",
      "import": "./dist/*/style/deps.js",
      "default": "./dist/*/style/deps.js"
    },
    "./src/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && vite build",
    "clean": "rimraf ./dist",
    "release": "npm run build && dsc publish --pnpm",
    "sync": "dsc sync"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/**/style/*",
    "dist/**/*.css"
  ],
  "keywords": [
    "vro",
    "vrojs",
    "ui",
    "element-plus",
    "vue"
  ],
  "author": "woshiajuana",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "copy-to-clipboard": "^3.3.3",
    "vue-draggable-plus": "^0.6.1"
  },
  "peerDependencies": {
    "@daysnap/banana": ">=0.0.15",
    "@daysnap/utils": ">=0.1.34",
    "@element-plus/icons-vue": ">=2.3.2",
    "@vrojs/base": "workspace:*",
    "@vrojs/use": "workspace:*",
    "element-plus": ">=2.11.9",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@daysnap/banana": "^0.0.15",
    "@daysnap/utils": "^0.1.34",
    "@element-plus/icons-vue": "^2.3.2",
    "@vrojs/base": "workspace:*",
    "@vrojs/use": "workspace:*",
    "@vitejs/plugin-vue": "^6.0.1",
    "element-plus": "^2.11.9",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.22"
  }
}
