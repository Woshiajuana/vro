{
  "name": "@vrojs/use",
  "version": "0.0.1",
  "type": "module",
  "description": "vrojs composables",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && tsup",
    "clean": "rimraf ./dist",
    "release": "pnpm run build && dsc publish --pnpm",
    "sync": "dsc sync"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "vro",
    "vrojs",
    "composables",
    "vue"
  ],
  "author": "woshiajuana",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@daysnap/utils": ">=0.1.33",
    "vue": ">=3.0.0",
    "vue-router": ">=4.2.4"
  },
  "devDependencies": {
    "@daysnap/utils": "^0.1.33",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vue": "^3.5.22"
  }
}
